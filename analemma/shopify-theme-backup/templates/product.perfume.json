    "testimonials": {
      "type": "testimonials",
      "blocks": {
        "testimonials-0": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>“The second product I have bought in the smaller size. Love the little tingle I get on my face after use and a couple of drops is enough.”<\/p>",
            "author": "Paige Alexander",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "testimonials-1": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>“Fantastic cleanser ! My skin is clean & fresh , ready to absorb the rest of my<br\/>Dr. Barbara Sturm skincare routine.”<\/p>",
            "author": "Claire Cooper",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "testimonials-2": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>“This cleanser is very lightweight & doesn’t dry out your skin like most cleansers. I have my teenage son using it & it has helped with his acne.”<\/p>",
            "author": "Sara Bond",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "testimonials-3": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>“I now don't want to use any other cleanser. Use it in the morning and evenings. It doesn't dry the skin and leaves it nicely clean.”<\/p>",
            "author": "Nikolay Balushev",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        },
        "testimonials-4": {
          "type": "testimonial",
          "settings": {
            "icon": "5",
            "text": "<p>“My skin feels soft and clean after using this cleanser because it’s very gentle and doesn't dry out my skin. i combine with the facial scrub every other day.”<\/p>",
            "author": "Angela McCafferty",
            "enable_highlight": false,
            "highlight_style": "marker"
          }
        }
      },
