    "sensory_experience": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{% case product.handle %}\n{% when 'tiramisu-tinted-lip-ganache' %}\n  {% assign sensory_text = \"Some shades are simple. This one has layers. Tiramisu opens with a cool espresso undertone -- grounded, slightly smoky, effortlessly polished. But underneath, warmth: cocoa-dusted softness, a creaminess that never feels severe. The scent blooms slowly. First the coffee note, roasted and rich. Then soft mascarpone, a dusting of cacao -- something that lingers the way a good dessert haunts you on the drive home.\" %}\n{% when 'raspberry-coulis-tinted-lip-ganache' %}\n  {% assign sensory_text = \"Bright, unapologetic, and a little bit wild. Raspberry Coulis opens like a burst of fresh berry -- tart, vivid, alive. The kind of shade that makes your eyes look brighter and your whole face more awake. The scent is pure raspberry, bright and sweet, the kind that makes you want to take another swipe just to smell it again.\" %}\n{% when 'strawberry-jam-tinted-lip-ganache' %}\n  {% assign sensory_text = \"The one that looks like you are wearing more than you are. Strawberry Jam is that perfect everyday red -- warm enough to feel wearable, vivid enough to feel intentional. The scent is exactly what it promises: ripe strawberries, sun-warm and sweet.\" %}\n{% when 'maraschino-cherry-tinted-lip-ganache' %}\n  {% assign sensory_text = \"Deep, cool, and quietly commanding. Maraschino Cherry is the shade for when you want your lips to do all the talking. A rich cherry red with cool undertones that makes every skin tone look like it was made for this colour. The scent: sweet cherry, bright and slightly tart.\" %}\n{% when 'hot-cocoa-tinted-lip-ganache' %}\n  {% assign sensory_text = \"Warm, earthy, and endlessly wearable. Hot Cocoa is the shade that has warmth, depth, and a richness that elevates everything. The scent is cosy cocoa and vanilla -- the kind that makes people lean a little closer.\" %}\n{% endcase %}\n{% if sensory_text != blank %}\n<div style=\"background:#ffffff;padding:72px 40px;border-top:1px solid #f0e8e0;\">\n  <div style=\"max-width:760px;margin:0 auto;text-align:center;\">\n    <p style=\"font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:#d4838f;margin:0 0 24px;\">The Sensory Experience<\/p>\n    <p style=\"font-size:18px;color:#2d2926;line-height:1.85;font-weight:300;font-style:italic;margin:0;\">{{ sensory_text }}<\/p>\n  <\/div>\n<\/div>\n{% endif %}",
        "full_width": false,
        "show_divider": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
