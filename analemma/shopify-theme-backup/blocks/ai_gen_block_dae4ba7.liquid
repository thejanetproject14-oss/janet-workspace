{% doc %}
  @prompt
    countdown timer for launch

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
    max-width: 100%;
  }

  .ai-countdown-timer__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px 0;
    font-weight: 600;
  }

  .ai-countdown-timer__subtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 {{ block.settings.spacing }}px 0;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.unit_spacing }}px;
    flex-wrap: wrap;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    background-color: {{ block.settings.unit_background_color }};
    border: {{ block.settings.unit_border_width }}px solid {{ block.settings.unit_border_color }};
    border-radius: {{ block.settings.unit_border_radius }}px;
    padding: {{ block.settings.unit_padding }}px;
    min-width: {{ block.settings.unit_min_width }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .ai-countdown-timer__number-{{ ai_gen_id }} {
    color: {{ block.settings.number_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    margin: 4px 0 0 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    color: {{ block.settings.expired_color }};
    font-size: {{ block.settings.expired_size }}px;
    font-weight: 600;
    margin: 0;
  }

  .ai-countdown-timer__button-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-countdown-timer__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer__display-{{ ai_gen_id }} {
      gap: {{ block.settings.unit_spacing | divided_by: 2 }}px;
    }

    .ai-countdown-timer__unit-{{ ai_gen_id }} {
      min-width: {{ block.settings.unit_min_width | times: 0.8 }}px;
      padding: {{ block.settings.unit_padding | times: 0.8 }}px;
    }

    .ai-countdown-timer__number-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.8 }}px;
    }

    .ai-countdown-timer__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-target-date="{{ block.settings.target_date }}"
  data-target-time="{{ block.settings.target_time }}"
  data-timezone="{{ block.settings.timezone }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-countdown-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if block.settings.subtext != blank %}
    <div class="ai-countdown-timer__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
  {% endif %}

  <div class="ai-countdown-timer__display-{{ ai_gen_id }}">
    {% if block.settings.show_days %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-days>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Days</div>
      </div>
    {% endif %}

    {% if block.settings.show_hours %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-hours>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Hours</div>
      </div>
    {% endif %}

    {% if block.settings.show_minutes %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-minutes>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Minutes</div>
      </div>
    {% endif %}

    {% if block.settings.show_seconds %}
      <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
        <div class="ai-countdown-timer__number-{{ ai_gen_id }}" data-seconds>00</div>
        <div class="ai-countdown-timer__label-{{ ai_gen_id }}">Seconds</div>
      </div>
    {% endif %}
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" style="display: none;">
    {{ block.settings.expired_message }}
  </div>

  {% if block.settings.button_text != blank and block.settings.button_link != blank %}
    <a href="{{ block.settings.button_link }}" class="ai-countdown-timer__button-{{ ai_gen_id }}">
      {{ block.settings.button_text }}
    </a>
  {% endif %}
</countdown-timer-{{ ai_gen_id }}><script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.interval = null;
      }

      connectedCallback() {
        this.targetDate = this.dataset.targetDate;
        this.targetTime = this.dataset.targetTime;
        this.timezone = this.dataset.timezone;

        if (!this.targetDate) {
          this.showExpired();
          return;
        }

        this.daysElement = this.querySelector('[data-days]');
        this.hoursElement = this.querySelector('[data-hours]');
        this.minutesElement = this.querySelector('[data-minutes]');
        this.secondsElement = this.querySelector('[data-seconds]');
        this.displayElement = this.querySelector('.ai-countdown-timer__display-{{ ai_gen_id }}');
        this.expiredElement = this.querySelector('.ai-countdown-timer__expired-{{ ai_gen_id }}');

        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);}
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const now = new Date().getTime();
        const targetDateTime = this.getTargetDateTime();
        const distance = targetDateTime - now;

        if (distance < 0) {
          this.showExpired();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysElement) this.daysElement.textContent = this.padNumber(days);
        if (this.hoursElement) this.hoursElement.textContent = this.padNumber(hours);
        if (this.minutesElement) this.minutesElement.textContent = this.padNumber(minutes);
        if (this.secondsElement) this.secondsElement.textContent = this.padNumber(seconds);}

      getTargetDateTime() {
        let dateTimeString = this.targetDate;
        if (this.targetTime) {
          dateTimeString += 'T' + this.targetTime;
        } else {
          dateTimeString += 'T00:00:00';
        }

        const targetDate = new Date(dateTimeString);
        if (this.timezone) {
          const offset = this.getTimezoneOffset(this.timezone);
          return targetDate.getTime() - (offset * 60 * 1000);
        }
        
        return targetDate.getTime();
      }

      getTimezoneOffset(timezone) {
        try {
          const now = new Date();
          const utc = new Date(now.getTime() + (now.getTimezoneOffset() * 60000));
          const targetTime = new Date(utc.toLocaleString('en-US', { timeZone: timezone }));
          return (utc.getTime() - targetTime.getTime()) / 60000;
        } catch (e) {
          return 0;
        }
      }

      padNumber(num) {
        return num.toString().padStart(2, '0');
      }

      showExpired() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        if (this.displayElement) this.displayElement.style.display = 'none';
        if (this.expiredElement) this.expiredElement.style.display = 'block';
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Countdown timer",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Launch countdown"
    },
    {
      "type": "textarea",
